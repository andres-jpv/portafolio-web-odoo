        <!-- ===== EXPERIENCIA ===== -->
        <record id="exp_freelance" model="portfolio.experience">
            <field name="developer_id" ref="developer_jordan"/>
            <field name="company">Proyecto Independiente / Freelance</field>
            <field name="position">Desarrollador Odoo Junior</field>
            <field name="location">Guayaquil, Ecuador</field>
            <field name="date_start">2025-05-01</field>
            <field name="is_current">True</field>
            <field name="highlights">Desarrollo de módulos completos con arquitectura profesional: modelos, vistas, seguridad, reportes QWeb y secuencias automáticas.
Implementación de lógica de negocio con decoradores (@api.depends, @api.constrains, @api.onchange) y métodos ORM (search, create, write, unlink).
Migración exitosa de módulos de Odoo 18 a 19, incluyendo refactorización de sintaxis deprecada y ajuste de vistas XML.
Configuración de entornos aislados con Docker/DevContainers y gestión de múltiples proyectos con archivos odoo.conf independientes.
Desarrollo de scripts de restauración automatizada de backups (dump.sql + filestore) usando PostgreSQL.</field>
        </record>

        <!-- ===== PROYECTOS ===== -->
        <record id="proj_library" model="portfolio.project">
            <field name="developer_id" ref="developer_jordan"/>
            <field name="name">Sistema de Gestión Bibliotecaria (Library App)</field>
            <field name="summary">Módulo integral para la administración de préstamos, autores y libros en Odoo.</field>
            <field name="highlights">Modelado relacional completo (Many2one, One2many, Many2many) con validaciones SQL (ISBN único) y constraints Python.
Wizards (TransientModel) para renovación masiva de préstamos con cálculos de fechas automatizados y validación de estados.
Seguridad por roles (Lector, Usuario, Bibliotecario) con herencia de grupos y reglas de registro dinámicas.
Reporte PDF de Carnet de Préstamo con QWeb, Bootstrap y lógica condicional (t-if, t-foreach).
Herencia de res.partner para agregar campo "Socio de Biblioteca" al modelo de Contactos.</field>
            <field name="sequence">1</field>
        </record>
        <record id="proj_sales" model="portfolio.project">
            <field name="developer_id" ref="developer_jordan"/>
            <field name="name">Sale.order — Extensión de Ventas</field>
            <field name="summary">Personalización técnica del núcleo de ventas de Odoo.</field>
            <field name="highlights">Herencia de modelos (_inherit sobre sale.order) y selectores XPath para inyectar campos en flujos de venta estándar.
Smart Buttons con campos computados y filtrado por dominio para seguimiento de transacciones en tiempo real.</field>
            <field name="sequence">2</field>
        </record>
        <record id="proj_n8n" model="portfolio.project">
            <field name="developer_id" ref="developer_jordan"/>
            <field name="name">Automatización Empresarial con n8n</field>
            <field name="summary">Flujos automatizados y agentes de IA para atención al cliente multicanal.</field>
            <field name="highlights">Chatbots multimodales con procesamiento de voz e imágenes, integrados a WhatsApp y Telegram.
Agentes RAG con bases vectoriales (Supabase/Pinecone) para consulta inteligente de documentos empresariales.
Escalamiento automático de conversaciones bot-a-humano mediante Chatwoot.</field>
            <field name="sequence">3</field>
        </record>

