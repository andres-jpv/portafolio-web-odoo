<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ====== PAPERFORMAT ====== -->
    <record id="paperformat_cv" model="report.paperformat">
        <field name="name">CV Jordan Pincay</field>
        <field name="default">False</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">8</field>
        <field name="margin_right">8</field>
        <field name="header_line">False</field>
        <field name="header_spacing">3</field>
        <field name="dpi">96</field>
    </record>

    <!-- ====== ACCIÓN DE REPORTE ====== -->
    <record id="action_report_cv" model="ir.actions.report">
        <field name="name">CV — Jordan Pincay</field>
        <field name="model">portfolio.developer</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">portafolio_web.report_cv_document</field>
        <field name="report_file">portafolio_web.report_cv_document</field>
        <field name="paperformat_id" ref="paperformat_cv"/>
    </record>

    <!-- ====== TEMPLATE QWEB ====== -->
    <template id="report_cv_document">
        <t t-call="web.html_container">
            <t t-set="full_width" t-value="True"/>
            <t t-foreach="docs" t-as="dev">
                <div class="article">
                <div class="page" style="
                    padding: 24px 32px;
                    font-family: 'Helvetica Neue', Arial, sans-serif;
                    font-size: 10pt;
                    color: #212529;
                    line-height: 1.5;
                ">

                    <!-- ── HEADER ── -->
                    <div style="text-align:center; padding-bottom:12px; border-bottom:2px solid #714b67; margin-bottom:16px;">
                        <h1 style="font-size:20pt; margin:0 0 4px; color:#1a1a2e;" t-out="dev.name"/>
                        <p style="margin:2px 0; color:#714b67; font-size:11pt; font-weight:600;" t-out="dev.job_title"/>
                        <p style="margin:4px 0; font-size:9pt; color:#6c757d;">
                            <t t-if="dev.location"><t t-out="dev.location"/></t>
                        </p>
                        <p style="margin:2px 0; font-size:9pt; color:#6c757d;">
                            <t t-if="dev.linkedin">linkedin.com/in/<t t-out="dev.linkedin"/>&#160;&#160;</t>
                            <t t-if="dev.github">github.com/<t t-out="dev.github"/></t>
                        </p>
                        <p style="margin:6px 0 0; font-size:8pt; color:#adb5bd;">Última actualización: Mar 2026</p>
                    </div>

                    <!-- ── PERFIL ── -->
                    <t t-if="dev.profile_bio">
                        <div style="margin-bottom:14px;">
                            <h2 style="font-size:10pt; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:#714b67; border-bottom:1px solid #dee2e6; padding-bottom:3px; margin-bottom:6px;">
                                Perfil
                            </h2>
                            <div style="font-size:9.5pt; color:#495057;" t-out="dev.profile_bio"/>
                        </div>
                    </t>

                    <!-- ── HABILIDADES (2 columnas) ── -->
                    <t t-if="dev.hard_skill_ids or dev.ecosystem_skill_ids">
                        <div style="margin-bottom:14px;">
                            <h2 style="font-size:10pt; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:#714b67; border-bottom:1px solid #dee2e6; padding-bottom:3px; margin-bottom:6px;">
                                Habilidades
                            </h2>
                            <table style="width:100%; border-collapse:collapse;">
                                <tr>
                                    <!-- Hard Skills -->
                                    <td style="width:50%; vertical-align:top; padding-right:10px;">
                                        <div style="font-size:8pt; font-weight:700; color:#6c757d; text-transform:uppercase; margin-bottom:4px;">Hard Skills / Framework</div>
                                        <t t-foreach="dev.hard_skill_ids" t-as="skill">
                                            <div style="font-size:9pt; padding:2px 0; border-bottom:1px solid #f5f5f5; color:#212529;">
                                                <t t-if="skill.checked"><span style="color:#28a745;">&#10003;</span> </t>
                                                <t t-out="skill.name"/>
                                            </div>
                                        </t>
                                    </td>
                                    <!-- Ecosistema -->
                                    <td style="width:50%; vertical-align:top; padding-left:10px; border-left:1px solid #f0f0f0;">
                                        <div style="font-size:8pt; font-weight:700; color:#6c757d; text-transform:uppercase; margin-bottom:4px;">Ecosistema / DevOps e IA</div>
                                        <t t-foreach="dev.ecosystem_skill_ids" t-as="skill">
                                            <div style="font-size:9pt; padding:2px 0; border-bottom:1px solid #f5f5f5; color:#212529;">
                                                <t t-if="skill.checked"><span style="color:#28a745;">&#10003;</span> </t>
                                                <t t-out="skill.name"/>
                                            </div>
                                        </t>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </t>

                    <!-- ── EXPERIENCIA ── -->
                    <t t-if="dev.experience_ids">
                        <div style="margin-bottom:14px;">
                            <h2 style="font-size:10pt; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:#714b67; border-bottom:1px solid #dee2e6; padding-bottom:3px; margin-bottom:6px;">
                                Experiencia
                            </h2>
                            <t t-foreach="dev.experience_ids" t-as="exp">
                                <div style="margin-bottom:10px;">
                                    <table style="width:100%; border-collapse:collapse;">
                                        <tr>
                                            <td style="font-size:9.5pt; font-weight:700; color:#212529;">
                                                <t t-out="exp.position"/>, <span style="color:#714b67;"><t t-out="exp.company"/></span>
                                                <t t-if="exp.location">
                                                    &#160;—&#160;<span style="color:#6c757d; font-weight:400; font-size:8.5pt;"><t t-out="exp.location"/></span>
                                                </t>
                                            </td>
                                            <td style="font-size:8.5pt; color:#6c757d; text-align:right; white-space:nowrap;">
                                                <t t-if="exp.date_start"><t t-out="exp.date_start"/></t>
                                                <t t-if="exp.is_current"> — presente</t>
                                                <t t-elif="exp.date_end"> — <t t-out="exp.date_end"/></t>
                                            </td>
                                        </tr>
                                    </table>
                                    <t t-if="exp.highlights">
                                        <ul style="margin:4px 0 0 16px; padding:0; font-size:9pt; color:#495057;">
                                            <t t-foreach="exp.highlights.split('\n')" t-as="line">
                                                <t t-if="line.strip()">
                                                    <li style="margin-bottom:2px;" t-out="line.strip()"/>
                                                </t>
                                            </t>
                                        </ul>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </t>

                    <!-- ── PROYECTOS ── -->
                    <t t-if="dev.project_ids">
                        <div style="margin-bottom:14px;">
                            <h2 style="font-size:10pt; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:#714b67; border-bottom:1px solid #dee2e6; padding-bottom:3px; margin-bottom:6px;">
                                Proyectos
                            </h2>
                            <t t-foreach="dev.project_ids" t-as="proj">
                                <div style="margin-bottom:8px;">
                                    <p style="margin:0; font-size:9.5pt; font-weight:700; color:#212529;" t-out="proj.name"/>
                                    <t t-if="proj.summary">
                                        <p style="margin:1px 0 2px; font-size:9pt; color:#6c757d;" t-out="proj.summary"/>
                                    </t>
                                    <t t-if="proj.highlights">
                                        <ul style="margin:2px 0 0 16px; padding:0; font-size:9pt; color:#495057;">
                                            <t t-foreach="proj.highlights.split('\n')" t-as="line">
                                                <t t-if="line.strip()">
                                                    <li style="margin-bottom:1px;" t-out="line.strip()"/>
                                                </t>
                                            </t>
                                        </ul>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </t>

                    <!-- ── EDUCACIÓN ── -->
                    <t t-if="dev.education_ids">
                        <div style="margin-bottom:14px;">
                            <h2 style="font-size:10pt; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:#714b67; border-bottom:1px solid #dee2e6; padding-bottom:3px; margin-bottom:6px;">
                                Educación
                            </h2>
                            <t t-foreach="dev.education_ids" t-as="edu">
                                <div style="margin-bottom:6px;">
                                    <table style="width:100%; border-collapse:collapse;">
                                        <tr>
                                            <td style="font-size:9.5pt; font-weight:700; color:#212529;">
                                                <t t-out="edu.institution"/>
                                                <t t-if="edu.degree">
                                                    , <span style="color:#714b67;"><t t-out="edu.degree"/><t t-if="edu.area"> en <t t-out="edu.area"/></t></span>
                                                </t>
                                                <t t-if="edu.location">
                                                    &#160;—&#160;<span style="color:#6c757d; font-weight:400; font-size:8.5pt;"><t t-out="edu.location"/></span>
                                                </t>
                                            </td>
                                            <td style="font-size:8.5pt; color:#6c757d; text-align:right; white-space:nowrap;">
                                                <t t-if="edu.date_start"><t t-out="edu.date_start"/></t>
                                                <t t-if="edu.date_end"> — <t t-out="edu.date_end"/></t>
                                            </td>
                                        </tr>
                                    </table>
                                    <t t-if="edu.highlights">
                                        <ul style="margin:3px 0 0 16px; padding:0; font-size:9pt; color:#495057;">
                                            <li t-out="edu.highlights"/>
                                        </ul>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </t>

                    <!-- ── CURSOS ── -->
                    <t t-if="dev.course_ids">
                        <div>
                            <h2 style="font-size:10pt; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:#714b67; border-bottom:1px solid #dee2e6; padding-bottom:3px; margin-bottom:6px;">
                                Cursos y Certificaciones
                            </h2>
                            <table style="width:100%; border-collapse:collapse;">
                                <t t-foreach="dev.course_ids" t-as="course">
                                    <tr style="border-bottom:1px solid #f5f5f5;">
                                        <td style="font-size:9pt; font-weight:600; color:#212529; padding:2px 0;" t-out="course.name"/>
                                        <td style="font-size:8.5pt; color:#6c757d; text-align:right; white-space:nowrap; padding:2px 0;">
                                            <t t-if="course.institution"><t t-out="course.institution"/>&#160;·&#160;</t>
                                            <t t-out="course.year"/>
                                        </td>
                                    </tr>
                                </t>
                            </table>
                        </div>
                    </t>

                </div>
                </div>
            </t>
        </t>
    </template>

</odoo>
