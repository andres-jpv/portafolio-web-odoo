<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portafolio_backend_page" name="Portafolio Web — Vista Backend">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
            <t t-set="additional_title">Portafolio Backend — <t t-esc="developer.name"/></t>

            <div class="ob-root">

                <!-- ====== NAVBAR ====== -->
                <nav class="ob-navbar">
                    <!-- Apps grid -->
                    <div class="ob-navbar__apps" title="Aplicaciones">&#8942;&#8942;&#8942;</div>

                    <!-- Brand -->
                    <span class="ob-navbar__brand">Portafolio</span>
                    <div class="ob-navbar__sep"/>

                    <!-- Menu items -->
                    <div class="ob-navbar__menu">
                        <span class="ob-navbar__menu-item active">Desarrolladores</span>
                    </div>

                    <!-- Derecha: iconos + usuario -->
                    <div class="ob-navbar__right">
                        <div class="ob-navbar__icon ob-navbar__icon--hidden-xs" title="Buscar">&#128269;</div>
                        <div class="ob-navbar__icon ob-navbar__icon--hidden-xs" title="Actividades">&#128336;</div>
                        <div class="ob-navbar__icon ob-navbar__icon--hidden-xs" title="Mensajes">&#128172;</div>
                        <div class="ob-navbar__user">
                            <div class="ob-navbar__avatar">
                                <t t-esc="developer.name[:2].upper() if developer.name else 'JP'"/>
                            </div>
                            <span class="ob-navbar__username ob-navbar__icon--hidden-xs" t-esc="developer.name"/>
                        </div>
                    </div>
                </nav>

                <!-- ====== CONTROL PANEL ====== -->
                <div class="ob-control-panel">
                    <div class="ob-control-panel__breadcrumb">
                        <a href="/portafolioweb">Desarrolladores</a>
                        <span class="sep">&#8250;</span>
                        <span class="current" t-esc="developer.name"/>
                    </div>
                    <div class="ob-control-panel__actions">
                        <a href="/portafolio" class="ob-btn ob-btn-secondary">
                            <!-- Switch icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/>
                            </svg>
                            v1 Web
                        </a>
                        <a href="/portafolioweb/cv"
                           class="ob-btn ob-btn-secondary">
                            <!-- Download icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
                            </svg>
                            Descargar CV
                        </a>
                        <a href="/portafolioweb/test"
                           target="_blank"
                           class="ob-btn ob-btn-secondary ob-btn--hidden-xs">
                            <!-- Target icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm0-12.5c-2.49 0-4.5 2.01-4.5 4.5s2.01 4.5 4.5 4.5 4.5-2.01 4.5-4.5-2.01-4.5-4.5-4.5zm0 5.5c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/>
                            </svg>
                            Test Técnico
                        </a>
                        <button type="button" id="ob-contactar-btn" class="ob-btn ob-btn-primary">
                            <!-- Mail icon -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                            </svg>
                            Contactar
                        </button>

                        <!-- ====== MODAL CONTACTO ====== -->
                        <div id="ob-contact-modal" class="ob-modal-overlay" style="display:none;">
                            <div class="ob-modal">
                                <div class="ob-modal__header">
                                    <h3 class="ob-modal__title">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:6px;">
                                            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                                        </svg>
                                        Enviar mensaje
                                    </h3>
                                    <button type="button" id="ob-modal-close" class="ob-modal__close">&#10005;</button>
                                </div>
                                <form id="ob-contact-form" method="post" action="/portafolioweb/contactar">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <div class="ob-modal__body">
                                        <div class="ob-modal__row">
                                            <div class="ob-modal__field">
                                                <label class="ob-modal__label">Nombre completo <span style="color:#e74c3c;">*</span></label>
                                                <input type="text" name="nombre" class="ob-modal__input" placeholder="Tu nombre" required="required"/>
                                            </div>
                                            <div class="ob-modal__field">
                                                <label class="ob-modal__label">Correo electrónico <span style="color:#e74c3c;">*</span></label>
                                                <input type="email" name="email" class="ob-modal__input" placeholder="tu@correo.com" required="required"/>
                                            </div>
                                        </div>
                                        <div class="ob-modal__row">
                                            <div class="ob-modal__field">
                                                <label class="ob-modal__label">Empresa / Organización</label>
                                                <input type="text" name="empresa" class="ob-modal__input" placeholder="Nombre de tu empresa (opcional)"/>
                                            </div>
                                            <div class="ob-modal__field">
                                                <label class="ob-modal__label">Cargo / Posición</label>
                                                <input type="text" name="cargo" class="ob-modal__input" placeholder="Tu cargo (opcional)"/>
                                            </div>
                                        </div>
                                        <div class="ob-modal__field" style="margin-top:10px;">
                                            <label class="ob-modal__label">Mensaje <span style="color:#e74c3c;">*</span></label>
                                            <textarea name="mensaje" class="ob-modal__textarea" rows="4" placeholder="¿En qué puedo ayudarte?" required="required"/>
                                        </div>
                                        <div id="ob-contact-status" class="ob-modal__status" style="display:none;"/>
                                    </div>
                                    <div class="ob-modal__footer">
                                        <button type="button" id="ob-modal-cancel" class="ob-btn ob-btn-secondary">Cancelar</button>
                                        <button type="submit" id="ob-contact-submit" class="ob-btn ob-btn-primary">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                                            </svg>
                                            Enviar mensaje
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ====== VIEW CONTAINER ====== -->
                <div class="ob-view-container">

                    <!-- ── FORM AREA ── -->
                    <div class="ob-form-area">
                        <div class="ob-sheet">

                            <!-- Ribbon DISPONIBLE -->
                            <t t-if="developer.is_available">
                                <div class="ob-ribbon">DISPONIBLE</div>
                            </t>

                            <!-- Stat buttons (only Proyectos + Versión) -->
                            <div class="ob-button-box">
                                <div class="ob-stat-btn">
                                    <span class="ob-stat-btn__value" t-esc="developer.project_count"/>
                                    <span class="ob-stat-btn__label">Proyectos</span>
                                </div>
                                <div class="ob-stat-btn">
                                    <span class="ob-stat-btn__value">v19</span>
                                    <span class="ob-stat-btn__label">Versión</span>
                                </div>
                            </div>

                            <!-- Header: foto + nombre -->
                            <div class="ob-header">
                                <t t-if="developer.photo">
                                    <img t-attf-src="data:image/png;base64,#{developer.photo}"
                                         class="ob-avatar"
                                         t-att-alt="developer.name"/>
                                </t>
                                <t t-else="">
                                    <div class="ob-avatar-placeholder">&#128100;</div>
                                </t>

                                <div class="ob-title">
                                    <h1 t-esc="developer.name"/>
                                    <h4 t-esc="developer.job_title"/>
                                    <div class="ob-tags">
                                        <t t-foreach="developer.skill_tag_ids" t-as="tag">
                                            <span class="ob-tag" t-esc="tag.name"/>
                                        </t>
                                    </div>
                                </div>
                            </div>

                            <!-- Grupo de campos (2 columnas) -->
                            <div class="ob-group">
                                <div class="ob-group-col">
                                    <t t-if="developer.location">
                                        <div class="ob-field-row">
                                            <span class="ob-field-label"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:4px;"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>Ubicación</span>
                                            <span class="ob-field-value" t-esc="developer.location"/>
                                        </div>
                                    </t>
                                    <t t-if="developer.linkedin">
                                        <div class="ob-field-row">
                                            <span class="ob-field-label"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:4px;"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>LinkedIn</span>
                                            <span class="ob-field-value">
                                                <a t-attf-href="https://linkedin.com/in/#{developer.linkedin}"
                                                   target="_blank" rel="noopener"
                                                   t-esc="developer.linkedin"/>
                                            </span>
                                        </div>
                                    </t>
                                </div>
                                <div class="ob-group-col">
                                    <t t-if="developer.category">
                                        <div class="ob-field-row">
                                            <span class="ob-field-label"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:4px;"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>Categoría</span>
                                            <span class="ob-field-value">
                                                <span class="ob-badge-category">
                                                    Developer / <t t-esc="developer.category.capitalize()"/>
                                                </span>
                                            </span>
                                        </div>
                                    </t>
                                    <t t-if="developer.github">
                                        <div class="ob-field-row">
                                            <span class="ob-field-label"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:4px;"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>GitHub</span>
                                            <span class="ob-field-value">
                                                <a t-attf-href="https://github.com/#{developer.github}"
                                                   target="_blank" rel="noopener"
                                                   t-esc="developer.github"/>
                                            </span>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <!-- ====== NOTEBOOK ====== -->
                            <div class="ob-notebook">
                                <div class="ob-notebook__tabs">
                                    <button class="ob-tab-btn active" data-ob-tab="info">
                                        Información General
                                    </button>
                                    <button class="ob-tab-btn" data-ob-tab="modulos">
                                        Módulos Desarrollados
                                    </button>
                                    <button class="ob-tab-btn" data-ob-tab="config">
                                        Formación y Certificaciones
                                    </button>
                                </div>

                                <!-- TAB 1: Información General -->
                                <div class="ob-tab-panel active" id="ob-panel-info">

                                    <!-- Perfil Profesional -->
                                    <t t-if="developer.profile_bio">
                                        <div class="ob-section-title">Perfil Profesional</div>
                                        <div class="ob-profile-bio" t-raw="developer.profile_bio"/>
                                    </t>

                                    <!-- Habilidades -->
                                    <t t-if="developer.hard_skill_ids or developer.ecosystem_skill_ids">
                                        <div class="ob-skills-row">
                                            <t t-if="developer.hard_skill_ids">
                                                <div>
                                                    <table class="ob-table">
                                                        <thead>
                                                            <tr>
                                                                <th>Habilidad</th>
                                                                <th style="width:50px;text-align:center;">&#10003;</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <t t-foreach="developer.hard_skill_ids" t-as="skill">
                                                                <tr>
                                                                    <td t-esc="skill.name"/>
                                                                    <td style="text-align:center;">
                                                                        <t t-if="skill.checked">
                                                                            <span class="ob-check-yes">&#10003;</span>
                                                                        </t>
                                                                    </td>
                                                                </tr>
                                                            </t>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </t>
                                            <t t-if="developer.ecosystem_skill_ids">
                                                <div>
                                                    <table class="ob-table">
                                                        <thead>
                                                            <tr>
                                                                <th>Tecnología</th>
                                                                <th style="width:50px;text-align:center;">&#10003;</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <t t-foreach="developer.ecosystem_skill_ids" t-as="skill">
                                                                <tr>
                                                                    <td t-esc="skill.name"/>
                                                                    <td style="text-align:center;">
                                                                        <t t-if="skill.checked">
                                                                            <span class="ob-check-yes">&#10003;</span>
                                                                        </t>
                                                                    </td>
                                                                </tr>
                                                            </t>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </t>
                                        </div>
                                    </t>

                                </div>

                                <!-- TAB 2: Módulos Desarrollados -->
                                <div class="ob-tab-panel" id="ob-panel-modulos">

                                    <t t-if="developer.experience_ids">
                                        <div class="ob-section-title">Experiencia Laboral</div>
                                        <table class="ob-table ob-table--responsive">
                                            <thead>
                                                <tr>
                                                    <th>Puesto</th>
                                                    <th>Empresa</th>
                                                    <th class="ob-col--hidden-xs">Ubicación</th>
                                                    <th class="ob-col--hidden-xs">Fecha inicio</th>
                                                    <th class="ob-col--hidden-xs">Fecha fin</th>
                                                    <th>Actual</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="developer.experience_ids" t-as="exp">
                                                    <tr>
                                                        <td t-esc="exp.position"/>
                                                        <td t-esc="exp.company"/>
                                                        <td class="muted ob-col--hidden-xs" t-esc="exp.location"/>
                                                        <td class="muted ob-col--hidden-xs" t-esc="exp.date_start"/>
                                                        <td class="muted ob-col--hidden-xs">
                                                            <t t-if="not exp.is_current" t-esc="exp.date_end"/>
                                                        </td>
                                                        <td style="text-align:center;">
                                                            <t t-if="exp.is_current">
                                                                <span class="ob-current-badge">Actual</span>
                                                            </t>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </t>

                                    <t t-if="developer.project_ids">
                                        <div class="ob-section-title">Proyectos</div>
                                        <table class="ob-table">
                                            <thead>
                                                <tr>
                                                    <th>Nombre del proyecto</th>
                                                    <th class="ob-col--hidden-xs">Resumen</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="developer.project_ids" t-as="proj">
                                                    <tr>
                                                        <td t-esc="proj.name"/>
                                                        <td class="muted ob-col--hidden-xs" t-esc="proj.summary"/>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </t>
                                </div>

                                <!-- TAB 3: Formación y Certificaciones -->
                                <div class="ob-tab-panel" id="ob-panel-config">

                                    <t t-if="developer.course_ids">
                                        <div class="ob-section-title">Cursos y Certificaciones</div>
                                        <table class="ob-table">
                                            <thead>
                                                <tr>
                                                    <th>Nombre del curso</th>
                                                    <th class="ob-col--hidden-xs">Institución / Plataforma</th>
                                                    <th style="width:70px;">Año</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="developer.course_ids" t-as="course">
                                                    <tr>
                                                        <td t-esc="course.name"/>
                                                        <td class="muted ob-col--hidden-xs" t-esc="course.institution"/>
                                                        <td class="muted" t-esc="course.year"/>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </t>

                                    <t t-if="developer.education_ids">
                                        <div class="ob-section-title">Educación</div>
                                        <table class="ob-table">
                                            <thead>
                                                <tr>
                                                    <th>Institución</th>
                                                    <th class="ob-col--hidden-xs">Título / Grado</th>
                                                    <th class="ob-col--hidden-xs">Área</th>
                                                    <th class="ob-col--hidden-xs">Inicio</th>
                                                    <th class="ob-col--hidden-xs">Fin</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="developer.education_ids" t-as="edu">
                                                    <tr>
                                                        <td t-esc="edu.institution"/>
                                                        <td class="muted ob-col--hidden-xs" t-esc="edu.degree"/>
                                                        <td class="muted ob-col--hidden-xs" t-esc="edu.area"/>
                                                        <td class="muted ob-col--hidden-xs" t-esc="edu.date_start"/>
                                                        <td class="muted ob-col--hidden-xs" t-esc="edu.date_end"/>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </t>
                                </div>

                            </div><!-- /ob-notebook -->

                        </div><!-- /ob-sheet -->
                    </div><!-- /ob-form-area -->

                    <!-- ── CHATTER ── -->
                    <div class="ob-chatter">
                        <div class="ob-chatter__header">
                            <div class="ob-chatter__tab active" id="ob-ctab-mensajes">Enviar mensaje</div>
                            <div class="ob-chatter__tab" id="ob-ctab-nota">Poner nota</div>
                        </div>

                        <!-- Panel: lista de notas (OWL monta aquí) -->
                        <div class="ob-chatter__body" id="ob-cpanel-mensajes">
                            <div id="ob-notas-root"/>
                        </div>

                        <!-- Panel: formulario nota -->
                        <div class="ob-chatter__body" id="ob-cpanel-nota" style="display:none;">
                            <div class="ob-nota-label">Dejar una nota</div>
                            <div class="ob-nota-field">
                                <label class="ob-nota-field-label">Tu nombre</label>
                                <input type="text" id="ob-nota-nombre"
                                       class="ob-nota-input"
                                       placeholder="Nombre..."/>
                            </div>
                            <div class="ob-nota-field">
                                <label class="ob-nota-field-label">Nota</label>
                                <textarea id="ob-nota-text"
                                          class="ob-nota-textarea"
                                          rows="5"
                                          placeholder="Escribe tu nota o comentario..."/>
                            </div>
                            <button id="ob-nota-submit" class="ob-nota-submit">
                                &#128221; Agregar nota
                            </button>
                            <div id="ob-nota-status" class="ob-nota-status" style="display:none;"/>
                        </div>
                    </div>

                </div><!-- /ob-view-container -->

            </div><!-- /ob-root -->

            <!-- ====== JS: Notebook tabs + Chatter tabs + Nota form + Modal Contacto ====== -->
            <script>
                document.addEventListener('DOMContentLoaded', function () {

                    // ── Modal Contactar ──
                    var modalOverlay = document.getElementById('ob-contact-modal');
                    var openBtn     = document.getElementById('ob-contactar-btn');
                    var closeBtn    = document.getElementById('ob-modal-close');
                    var cancelBtn   = document.getElementById('ob-modal-cancel');
                    var contactForm = document.getElementById('ob-contact-form');
                    var statusDiv   = document.getElementById('ob-contact-status');

                    function openModal()  { modalOverlay.style.display = 'flex'; }
                    function closeModal() { modalOverlay.style.display = 'none'; statusDiv.style.display = 'none'; contactForm.reset(); }

                    if (openBtn)   openBtn.addEventListener('click', openModal);
                    if (closeBtn)  closeBtn.addEventListener('click', closeModal);
                    if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
                    if (modalOverlay) {
                        modalOverlay.addEventListener('click', function (e) {
                            if (e.target === modalOverlay) closeModal();
                        });
                    }

                    if (contactForm) {
                        contactForm.addEventListener('submit', function (e) {
                            e.preventDefault();
                            var submitBtn = document.getElementById('ob-contact-submit');
                            submitBtn.disabled = true;
                            submitBtn.textContent = 'Enviando...';
                            var formData = new FormData(contactForm);
                            fetch('/portafolioweb/contactar', {
                                method: 'POST',
                                body: formData,
                            }).then(function (r) { return r.json(); }).then(function (data) {
                                statusDiv.style.display = 'block';
                                if (data.ok) {
                                    statusDiv.className = 'ob-modal__status ob-modal__status--ok';
                                    statusDiv.textContent = '¡Mensaje enviado! Te responderé lo antes posible.';
                                    contactForm.reset();
                                    setTimeout(closeModal, 2500);
                                } else {
                                    statusDiv.className = 'ob-modal__status ob-modal__status--err';
                                    statusDiv.textContent = data.error || 'Error al enviar. Intenta de nuevo.';
                                }
                            }).catch(function () {
                                statusDiv.style.display = 'block';
                                statusDiv.className = 'ob-modal__status ob-modal__status--err';
                                statusDiv.textContent = 'Error de conexión. Intenta de nuevo.';
                            }).finally(function () {
                                submitBtn.disabled = false;
                                submitBtn.textContent = 'Enviar mensaje';
                            });
                        });
                    }

                    // ── Notebook tabs ──
                    var tabs = document.querySelectorAll('.ob-tab-btn');
                    var panels = document.querySelectorAll('.ob-tab-panel');
                    tabs.forEach(function (btn) {
                        btn.addEventListener('click', function () {
                            var target = btn.getAttribute('data-ob-tab');
                            tabs.forEach(function (t) { t.classList.remove('active'); });
                            panels.forEach(function (p) { p.classList.remove('active'); });
                            btn.classList.add('active');
                            var panel = document.getElementById('ob-panel-' + target);
                            if (panel) { panel.classList.add('active'); }
                        });
                    });

                    // ── Chatter tabs ──
                    var ctabMensajes = document.getElementById('ob-ctab-mensajes');
                    var ctabNota = document.getElementById('ob-ctab-nota');
                    var cpanelMensajes = document.getElementById('ob-cpanel-mensajes');
                    var cpanelNota = document.getElementById('ob-cpanel-nota');

                    if (ctabMensajes &amp;&amp; ctabNota) {
                        ctabMensajes.addEventListener('click', function () {
                            cpanelNota.style.display = 'none';
                            cpanelMensajes.style.display = 'block';
                            ctabNota.classList.remove('active');
                            ctabMensajes.classList.add('active');
                        });
                        ctabNota.addEventListener('click', function () {
                            cpanelMensajes.style.display = 'none';
                            cpanelNota.style.display = 'block';
                            ctabMensajes.classList.remove('active');
                            ctabNota.classList.add('active');
                        });
                    }

                    // ── Nota form submit ──
                    var notaSubmit = document.getElementById('ob-nota-submit');
                    var notaStatus = document.getElementById('ob-nota-status');
                    if (notaSubmit) {
                        notaSubmit.addEventListener('click', function () {
                            var nombre = (document.getElementById('ob-nota-nombre').value || '').trim();
                            var texto = (document.getElementById('ob-nota-text').value || '').trim();
                            if (!texto) {
                                notaStatus.style.display = 'block';
                                notaStatus.className = 'ob-nota-status ob-nota-status--warn';
                                notaStatus.textContent = 'Por favor escribe una nota.';
                                return;
                            }
                            // Dispatch event so OWL component updates its list
                            window.dispatchEvent(new CustomEvent('pf-nota-nueva', {
                                detail: { nombre: nombre, texto: texto }
                            }));
                            // Clear form and switch to messages tab
                            document.getElementById('ob-nota-nombre').value = '';
                            document.getElementById('ob-nota-text').value = '';
                            notaStatus.style.display = 'block';
                            notaStatus.className = 'ob-nota-status ob-nota-status--ok';
                            notaStatus.textContent = '\u00a1Nota agregada!';
                            setTimeout(function () {
                                notaStatus.style.display = 'none';
                                if (ctabMensajes) ctabMensajes.click();
                            }, 700);
                        });
                    }
                });
            </script>

        </t>
    </template>

</odoo>
